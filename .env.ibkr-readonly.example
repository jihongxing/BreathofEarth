# IBKR Stage 9.5 read-only observation template.
#
# Copy values into your local secret manager or local .env only.
# Do not commit real account ids, conids, Client Portal URLs, tokens, or secrets.
#
# Absolute red lines:
# - Do not set IBKR_ENABLE_ORDER_SUBMISSION here.
# - Do not set XIRANG_ENABLE_LIVE_CORE_EXECUTION here.
# - Do not set XIRANG_LIVE_CORE_APPROVAL_ID here.

# Required: local IBKR Client Portal Gateway base URL.
IBKR_API_BASE_URL=https://127.0.0.1:5000/v1/api

# Required: paper or real account id for read-only observation.
IBKR_ACCOUNT_ID=

# Recommended connection settings.
IBKR_VERIFY_TLS=true
IBKR_TIMEOUT_SEC=10
IBKR_ORDER_TIF=DAY
IBKR_LISTING_EXCHANGE=SMART
IBKR_REPLY_CONFIRM_LIMIT=3

# Required explicit conid mappings for production observation assets.
# Keep them blank until manually verified in IBKR Client Portal.
IBKR_CONID_SPY=
IBKR_CONID_TLT=
IBKR_CONID_GLD=
IBKR_CONID_SHV=
IBKR_CONID_QQQ=

# Optional: point Stage 9.5 outputs at a dedicated read-only evidence folder.
# XIRANG_SHADOW_AUDIT_DIR=data/shadow
